@using Microsoft.AspNetCore.Identity
@inject SignInManager<Narrowcasting.Models.ApplicationUser> SignInManager
@inject UserManager<Narrowcasting.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NC Admin – @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --sidebar-bg: #1a1d23;
            --sidebar-width: 240px;
            --topbar-height: 56px;
            --accent: #0d6efd;
            --sidebar-text: #adb5bd;
            --sidebar-hover: #2c3040;
            --sidebar-active: #0d6efd;
        }

        html, body {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        body {
            display: flex;
            flex-direction: column;
            background: #f4f6fb;
        }

        /* ── Topbar ── */
        #topbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: var(--topbar-height);
            background: var(--sidebar-bg);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1rem;
            z-index: 1040;
        }

            #topbar .brand {
                font-weight: 700;
                font-size: 1.1rem;
                color: #fff;
                text-decoration: none;
            }

                #topbar .brand span {
                    color: var(--accent);
                }

        #sidebar-toggle {
            background: none;
            border: none;
            color: #adb5bd;
            font-size: 1.2rem;
            cursor: pointer;
        }

        /* ── Sidebar ── */
        #sidebar {
            position: fixed;
            top: var(--topbar-height);
            left: 0;
            bottom: 0;
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            overflow-y: auto;
            z-index: 1030;
            transition: transform .25s;
        }

            #sidebar .nav-section {
                font-size: .65rem;
                font-weight: 700;
                letter-spacing: .08em;
                color: #6c757d;
                text-transform: uppercase;
                padding: 1.25rem 1rem .4rem;
            }

            #sidebar .nav-link {
                color: var(--sidebar-text);
                padding: .5rem 1rem;
                border-radius: 6px;
                margin: 1px 8px;
                display: flex;
                align-items: center;
                gap: .6rem;
                font-size: .875rem;
                text-decoration: none;
                transition: background .15s, color .15s;
            }

                #sidebar .nav-link:hover {
                    background: var(--sidebar-hover);
                    color: #fff;
                }

                #sidebar .nav-link.active {
                    background: var(--accent);
                    color: #fff;
                }

                #sidebar .nav-link i {
                    width: 18px;
                    text-align: center;
                    font-size: 1rem;
                }

        /* ── Main content ── */
        #main-wrapper {
            margin-left: var(--sidebar-width);
            margin-top: var(--topbar-height);
            padding: 2rem;
            min-height: calc(100vh - var(--topbar-height));
            transition: margin-left .25s;
        }

        .page-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1a1d23;
        }

        .breadcrumb-item, .breadcrumb-item a {
            font-size: .825rem;
            color: #6c757d;
            text-decoration: none;
        }

        /* ── Stat cards ── */
        .stat-card {
            border: none;
            border-radius: 10px;
            color: #fff;
            padding: 1.25rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
        }

            .stat-card .stat-label {
                font-size: .8rem;
                opacity: .85;
            }

            .stat-card .stat-value {
                font-size: 2rem;
                font-weight: 700;
            }

            .stat-card .stat-icon {
                font-size: 2.5rem;
                opacity: .35;
            }

            .stat-card a.stretched-link {
                color: inherit;
                font-size: .8rem;
                text-decoration: underline;
            }

        /* ── Sidebar collapsed ── */
        body.sidebar-collapsed #sidebar {
            transform: translateX(calc(-1 * var(--sidebar-width)));
        }

        body.sidebar-collapsed #main-wrapper {
            margin-left: 0;
        }

        /* ── Table styles ── */
        .nc-table th {
            font-size: .78rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #6c757d;
            border-top: none;
        }

        .badge-active {
            background: #d1fae5;
            color: #065f46;
        }

        .badge-inactive {
            background: #fee2e2;
            color: #991b1b;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ── Topbar ── -->
    <div id="topbar">
        <div class="d-flex align-items-center gap-3">
            <button id="sidebar-toggle" onclick="toggleSidebar()">
                <i class="bi bi-list"></i>
            </button>
            <a class="brand" asp-page="/Admin/Dashboard/Index">NC <span>Admin</span></a>
        </div>
        <div class="d-flex align-items-center gap-3">
            @if (SignInManager.IsSignedIn(User))
            {
                <span class="text-secondary small">Hallo @User.Identity!.Name!</span>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><span class="dropdown-item-text small text-muted">@User.Identity!.Name</span></li>
                        <li>
                            <a class="dropdown-item small" asp-area="Identity" asp-page="/Account/Manage/Index">
                                <i class="bi bi-gear me-2"></i>Mijn account
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-area="Identity" asp-page="/Account/Logout"
                                  asp-route-returnUrl="@Url.Page("/Admin/Dashboard/Index", new { area = "" })"
                                  method="post">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Uitloggen
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
        </div>
    </div>

    <!-- ── Sidebar ── -->
    <nav id="sidebar">
        <div class="nav-section">Core</div>
        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Dashboard") == true ? "active" : "")"
           asp-page="/Admin/Dashboard/Index">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="nav-section">Beheer</div>
        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Departments") == true ? "active" : "")"
           asp-page="/Admin/Departments/Index">
            <i class="bi bi-building"></i> Afdelingen
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Screens") == true ? "active" : "")"
           asp-page="/Admin/Screens/Index">
            <i class="bi bi-display"></i> Schermen
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Playlists") == true ? "active" : "")"
           asp-page="/Admin/Playlists/Index">
            <i class="bi bi-collection-play"></i> Playlists
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/MediaFiles") == true ? "active" : "")"
           asp-page="/Admin/MediaFiles/Index">
            <i class="bi bi-images"></i> Mediabestanden
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Announcements") == true ? "active" : "")"
           asp-page="/Admin/Announcements/Index">
            <i class="bi bi-megaphone"></i> Aankondigingen
        </a>

        @if (User.IsInRole("Admin"))
        {
            <div class="nav-section">Administratie</div>
            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Users") == true ? "active" : "")"
               asp-page="/Admin/Users/Index">
                <i class="bi bi-people"></i> Gebruikers
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/AuditLog") == true ? "active" : "")"
               asp-page="/Admin/AuditLog/Index">
                <i class="bi bi-shield-check"></i> Auditlog
            </a>
        }

        <div class="nav-section mt-3">Publiek</div>
        <a class="nav-link" href="/" target="_blank">
            <i class="bi bi-box-arrow-up-right"></i> Publieke site
        </a>
    </nav>

    <!-- ── Main ── -->
    <div id="main-wrapper">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.body.classList.toggle('sidebar-collapsed');
            localStorage.setItem('sidebarCollapsed', document.body.classList.contains('sidebar-collapsed'));
        }
        // Restore state
        if (localStorage.getItem('sidebarCollapsed') === 'true') {
            document.body.classList.add('sidebar-collapsed');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

