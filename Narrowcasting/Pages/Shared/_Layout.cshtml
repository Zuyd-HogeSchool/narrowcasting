<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ziekenhuis Informatie – @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --primary: #005EB8; /* NHS-style hospital blue */
            --primary-dark: #00408c;
        }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .navbar {
            background: var(--primary) !important;
        }

        .navbar-brand, .nav-link {
            color: #fff !important;
        }

            .nav-link:hover {
                opacity: .85;
            }

        .hero-bar {
            background: var(--primary);
            color: #fff;
            padding: 2.5rem 0;
        }

        footer {
            background: #1a1d23;
            color: #adb5bd;
            font-size: .85rem;
        }
    </style>
</head>
<body>
    <div class="topbar py-2">
        <div class="container d-flex justify-content-end gap-4">
            <a href="#">Werken bij</a>
            <a href="#">Medewerkers</a>
            <a href="/About">Over ons</a>
            <a href="#">Contact</a>
            <a href="#">Zoeken</a>
            <a href="#">Mijn Ziekenhuis+</a>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="bi bi-hospital me-2"></i>Ziekenhuis</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto gap-2">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Cast">Schermen</a></li>
                    <li class="nav-item"><a class="nav-link" href="/About">Over ons</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year Ziekenhuis</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
