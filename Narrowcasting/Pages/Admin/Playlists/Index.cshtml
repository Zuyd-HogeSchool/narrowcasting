@page
@model Narrowcasting.Pages.Admin.Playlists.IndexModel
@{
    ViewData["Title"] = "Playlists";
}

<div class="d-flex justify-content-between align-items-start mb-1">
    <div>
        <h1 class="page-title">Playlists</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Admin/Dashboard/Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Playlists</li>
            </ol>
        </nav>
    </div>
    <a asp-page="/Admin/Playlists/Edit" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Nieuwe playlist
    </a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string errMsg)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 small">
        <i class="bi bi-exclamation-triangle me-2"></i>@errMsg
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mt-1">
    @foreach (var playlist in Model.Playlists)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="fw-bold mb-0">@playlist.Name</h6>
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-music-note-list me-1"></i>@playlist.Items.Count items
                        </span>
                    </div>
                    <p class="text-muted small mb-1">
                        <i class="bi bi-display me-1"></i>@playlist.Screen?.Name
                    </p>
                    <p class="text-muted small mb-3">
                        <i class="bi bi-building me-1"></i>@playlist.Screen?.Department?.Name
                    </p>
                    <div class="d-flex gap-2">
                        <a asp-page="/Admin/Playlists/Edit" asp-route-id="@playlist.Id"
                           class="btn btn-sm btn-outline-secondary flex-fill">
                            <i class="bi bi-pencil me-1"></i>Beheren
                        </a>
                        <form method="post" asp-page-handler="Delete" class="flex-fill">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@playlist.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                                    onclick="return confirm('Playlist \'@playlist.Name\' verwijderen?')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (!Model.Playlists.Any())
    {
        <div class="col-12 text-center text-muted py-5">Geen playlists gevonden.</div>
    }
</div>
