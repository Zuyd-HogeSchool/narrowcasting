@page
@model Narrowcasting.Pages.Admin.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-start mb-1">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item active">Dashboard</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Stat cards -->
<div class="row g-3 mt-1">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:#0d6efd;">
            <div>
                <div class="stat-label">Afdelingen</div>
                <div class="stat-value">@Model.DepartmentCount</div>
                <a asp-page="/Admin/Departments/Index" class="stretched-link">Bekijk alles &rsaquo;</a>
            </div>
            <i class="bi bi-building stat-icon"></i>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:#f59e0b;">
            <div>
                <div class="stat-label">Schermen</div>
                <div class="stat-value">@Model.ScreenCount</div>
                <a asp-page="/Admin/Screens/Index" class="stretched-link">Bekijk alles &rsaquo;</a>
            </div>
            <i class="bi bi-display stat-icon"></i>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:#10b981;">
            <div>
                <div class="stat-label">Playlists</div>
                <div class="stat-value">@Model.PlaylistCount</div>
                <a asp-page="/Admin/Playlists/Index" class="stretched-link">Bekijk alles &rsaquo;</a>
            </div>
            <i class="bi bi-collection-play stat-icon"></i>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:#ef4444;">
            <div>
                <div class="stat-label">Aankondigingen</div>
                <div class="stat-value">@Model.AnnouncementCount</div>
                <a asp-page="/Admin/Announcements/Index" class="stretched-link">Bekijk alles &rsaquo;</a>
            </div>
            <i class="bi bi-megaphone stat-icon"></i>
        </div>
    </div>
</div>

<!-- Recent activity -->
<div class="row g-3 mt-2">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 fw-semibold">
                <i class="bi bi-display me-2 text-primary"></i>Schermen overzicht
            </div>
            <div class="card-body p-0">
                <table class="table nc-table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Naam</th>
                            <th>Afdeling</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var screen in Model.RecentScreens)
                        {
                            <tr>
                                <td class="fw-medium">@screen.Name</td>
                                <td class="text-muted small">@screen.Department?.Name</td>
                                <td>
                                    @if (screen.IsActive)
                                    {
                                        <span class="badge badge-active rounded-pill">Actief</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-inactive rounded-pill">Inactief</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 fw-semibold">
                <i class="bi bi-clock-history me-2 text-warning"></i>Recente activiteit
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var log in Model.RecentLogs)
                    {
                        <li class="list-group-item px-3 py-2 small">
                            <div class="d-flex justify-content-between">
                                <span>
                                    <span class="fw-medium">@log.User?.FullName</span>
                                    <span class="text-muted">–</span>
                                    <span class="text-primary">@log.Action</span>
                                    <span class="text-muted">@log.EntityType</span>
                                </span>
                            </div>
                            <div class="text-muted" style="font-size:.75rem">@log.Timestamp.ToLocalTime().ToString("dd-MM HH:mm")</div>
                        </li>
                    }
                    @if (!Model.RecentLogs.Any())
                    {
                        <li class="list-group-item text-muted small px-3">Geen recente activiteit.</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
