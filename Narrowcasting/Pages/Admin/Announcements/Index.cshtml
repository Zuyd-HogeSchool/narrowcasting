@page
@model Narrowcasting.Pages.Admin.Announcements.IndexModel
@{
    ViewData["Title"] = "Announcements";
}

<div class="d-flex justify-content-between align-items-start mb-1">
    <div>
        <h1 class="page-title">Aankondigingen</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Admin/Dashboard/Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Aankondigingen</li>
            </ol>
        </nav>
    </div>
    <a asp-page="/Admin/Announcements/Edit" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Nieuwe aankondiging
    </a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small">
        <i class="bi bi-check-circle me-2"></i>@msg
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mt-3">
    <div class="card-body p-0">
        <table class="table nc-table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Titel</th>
                    <th>Afdeling</th>
                    <th>Gepubliceerd</th>
                    <th>Vervalt</th>
                    <th>Type</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Announcements)
                {
                    var expired = a.ExpiresAt.HasValue && a.ExpiresAt < DateTime.UtcNow;
                    <tr class="@(expired ? "table-secondary text-muted" : "")">
                        <td class="fw-medium">@a.Title</td>
                        <td class="small">@a.Department?.Name</td>
                        <td class="small">@a.PublishedAt.ToLocalTime().ToString("dd-MM-yyyy")</td>
                        <td class="small">
                            @if (a.ExpiresAt.HasValue)
                            {
                                if (expired)
                                {
                                    <span class="text-danger small"><i class="bi bi-x-circle me-1"></i>Verlopen</span>
                                }
                                else
                                {

                                    @a.ExpiresAt.Value.ToLocalTime().ToString("dd-MM-yyyy")
                                }
                            }
                            else
                            {

                                <span class="text-muted">–</span>
                            }
                        </td>
                        <td>
                            @if (a.IsInternal)
                            {
                                <span class="badge bg-secondary rounded-pill">Intern</span>
                            }
                            else
                            {

                                <span class="badge bg-info text-dark rounded-pill">Publiek</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-page="/Admin/Announcements/Edit" asp-route-id="@a.Id"
                               class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-page-handler="Delete" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@a.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Aankondiging verwijderen?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Announcements.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Geen aankondigingen.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
