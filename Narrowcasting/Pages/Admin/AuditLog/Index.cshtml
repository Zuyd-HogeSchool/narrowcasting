@page
@model Narrowcasting.Pages.Admin.AuditLog.IndexModel
@{
    ViewData["Title"] = "Audit log";
}

<div class="d-flex justify-content-between align-items-start mb-1">
    <div>
        <h1 class="page-title">Auditlog</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Admin/Dashboard/Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Auditlog</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2">
            <div class="col-md-4">
                <input type="text" name="userId" value="@Model.FilterUserId"
                       class="form-control form-control-sm" placeholder="Filter op gebruiker-ID..." />
            </div>
            <div class="col-md-3">
                <input type="date" name="from" value="@Model.FilterFrom?.ToString("yyyy-MM-dd")"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <input type="date" name="to" value="@Model.FilterTo?.ToString("yyyy-MM-dd")"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-sm btn-primary w-100">Filteren</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table nc-table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Tijdstip</th>
                    <th>Gebruiker</th>
                    <th>Actie</th>
                    <th>Entiteit</th>
                    <th>ID</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs)
                {
                    <tr>
                        <td class="small text-muted">@log.Timestamp.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</td>
                        <td class="small fw-medium">@log.User?.FullName</td>
                        <td>
                            <span class="badge @(log.Action == "Delete" ? "bg-danger" : log.Action == "Create" ? "bg-success" : "bg-secondary") rounded-pill">
                                @log.Action
                            </span>
                        </td>
                        <td class="small">@log.EntityType</td>
                        <td class="small text-muted">@log.EntityId</td>
                        <td class="small text-muted">@log.Details</td>
                    </tr>
                }
                @if (!Model.Logs.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Geen logs gevonden.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>