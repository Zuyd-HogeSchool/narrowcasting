@page "{id}"
@model Narrowcasting.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "Gebruiker bewerken";
}

<div class="d-flex justify-content-between align-items-start mb-1">
    <div>
        <h1 class="page-title">Gebruiker bewerken</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Admin/Dashboard/Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-page="/Admin/Users/Index">Gebruikers</a></li>
                <li class="breadcrumb-item active">Bewerken</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Input.Id" />
                    <input type="hidden" asp-for="Input.IsActive" />

                    @if (!Model.Input.IsActive && Model.Input.Role == "Employee" && Model.Input.DepartmentId is null)
                    {
                        <div class="alert alert-warning py-2 small">
                            Deze gebruiker wacht op goedkeuring. Kies een afdeling en sla op om het account te activeren.
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Input.FullName" class="form-label fw-medium small">Volledige naam *</label>
                        <input asp-for="Input.FullName" class="form-control" />
                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium small">E-mailadres</label>
                        <input value="@Model.Input.Email" class="form-control" disabled />
                        <div class="form-text">E-mailadres kan hier niet gewijzigd worden.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Role" class="form-label fw-medium small">Rol *</label>
                        <select asp-for="Input.Role" class="form-select">
                            <option value="Employee">Employee</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.DepartmentId" class="form-label fw-medium small">
                            Afdeling <span class="text-muted">(verplicht voor Employee, leeg = Admin)</span>
                        </label>
                        <select asp-for="Input.DepartmentId" class="form-select" asp-items="@Model.DepartmentSelectList">
                            <option value="">– Geen (Admin) –</option>
                        </select>
                        <span asp-validation-for="Input.DepartmentId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i>Opslaan
                        </button>
                        <a asp-page="/Admin/Users/Index" class="btn btn-outline-secondary">Annuleren</a>
                    </div>
                </form>

                <hr class="my-4" />

                <h6 class="fw-bold small text-danger">Wachtwoord resetten</h6>
                <p class="text-muted small">Genereert direct een nieuw tijdelijk wachtwoord voor deze gebruiker.</p>
                <form method="post" asp-page-handler="ResetPassword">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Input.Id" />
                    <div class="input-group" style="max-width:320px">
                        <input type="text" name="newPassword" class="form-control form-control-sm"
                               placeholder="Nieuw wachtwoord" required />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Reset</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
