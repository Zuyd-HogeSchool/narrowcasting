@{
    // Prefer explicit query flag (set by admin UI links). Fall back to role check.
    var layoutQuery = Context.Request.Query["layout"].ToString();

    if (!string.IsNullOrEmpty(layoutQuery) && layoutQuery == "admin")
    {
        Layout = "/Pages/Shared/_AdminLayout.cshtml";
    }
    else if (User?.Identity?.IsAuthenticated == true &&
             (User.IsInRole("Admin") || User.IsInRole("Employee")))
    {
        Layout = "/Pages/Shared/_AdminLayout.cshtml";
    }
    else
    {
        Layout = "/Pages/Shared/_Layout.cshtml";
    }
}

<h1>Manage your account</h1>

<div>
    <h2>Change your account settings</h2>
    <hr />
    <div class="row">
        <div class="col-md-3">
            <partial name="_ManageNav" />
        </div>
        <div class="col-md-9">
            @RenderBody()
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}